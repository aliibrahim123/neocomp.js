{
	"tasks": {
		"start": "vite .",
		"build": "vite build ."
	},
	"lint": {
		"include": ["src/"],
		"rules": {
			"tags": ["recommended"],
			"exclude": ["prefer-const", "no-explicit-any", "no-inner-declarations"]
		}
	},
	"permissions": {
		"default": {
			"read": ["."],
			"write": ["."],
			"net": true,
			"env": true
		}
	}
}
